# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/meditrack

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated allowed web origins (production + previews)
FRONTEND_URLS=http://localhost:3000
# Optional: startup migration retry tuning for managed databases
DB_MIGRATION_ATTEMPTS=30
DB_MIGRATION_RETRY_DELAY_MS=5000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com → API Keys
# Leave blank during local development to log emails to the console instead
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=meditrack <noreply@yourdomain.com>

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
# Preferred: Meta WhatsApp Cloud API (same style as Flowjuyu)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=v23.0

# Optional fallback: Twilio WhatsApp
# https://console.twilio.com
# Leave all WhatsApp vars blank during local development to log messages to the console instead
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio Sandbox: whatsapp:+14155238886  (prod: your registered number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Storage (AWS S3 or compatible, e.g. MinIO / Cloudflare R2) ───────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=meditrack-documents
# Optional: uncomment for S3-compatible services (MinIO, R2, etc.)
# AWS_S3_ENDPOINT=http://localhost:9000

# ─── Billing / Pagos Guatemala ────────────────────────────────────────────────
# Provider recomendado para Guatemala: Recurrente.
# Mantener Stripe solo como fallback opcional para cuentas internacionales.
PAYMENT_PROVIDER=recurrente

# Recurrente → Configuración → Llaves API
RECURRENTE_API_BASE=https://app.recurrente.com/api
# Preferida para API REST según documentación pública.
RECURRENTE_SECRET_KEY=
# Compatibilidad con Flowjuyu/local legacy para checkout hosted.
RECURRENTE_PUBLIC_KEY=
# Recurrente → Desarrolladores/API → Webhooks
# URL sugerida: https://tu-api.com/api/v1/billing/webhook/recurrente
# Evento principal: payment_intent.succeeded
RECURRENTE_WEBHOOK_SECRET=
RECURRENTE_WEBHOOK_MAX_SKEW_SECONDS=300

# ─── Stripe Billing opcional ──────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
# Leave blank during local development to disable Stripe fallback.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Products → Doctor Individual → copy Price ID
STRIPE_DOCTOR_INDIVIDUAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Products → Clínica Completa → copy Price ID
STRIPE_CLINIC_COMPLETE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Legacy fallback for older local setups. Prefer the plan-specific variables above.
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Developers → Webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Clinical AI Providers ───────────────────────────────────────────────────
# local = deterministic in-app assistant. openai/anthropic = external paid LLMs.
# Keep AI_EXTERNAL_ENABLED=false until you have a signed provider/data policy.
AI_PROVIDER=local
AI_EXTERNAL_ENABLED=false
AI_FALLBACK_TO_LOCAL=true
AI_PROVIDER_TIMEOUT_MS=25000

# OpenAI Responses API. Recommended budget model for clinical copilot drafts.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Premium option for doctors/clinics willing to pay more for deeper reasoning.
OPENAI_PREMIUM_MODEL=gpt-5.5

# Anthropic Messages API. Haiku is the lower-cost default available in newer accounts; Sonnet 4 is stronger.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_PREMIUM_MODEL=claude-sonnet-4-6

# ─── Demo Data Seeds ─────────────────────────────────────────────────────────
# Optional: target doctor/clinic account for demo patient seed scripts.
# If the doctor does not exist, the triage demo seed creates it automatically.
DEMO_SEED_TRIAGE_PATIENTS=false
DEMO_DOCTOR_EMAIL=demo.ai@meditrack.app
DEMO_DOCTOR_PASSWORD=DemoIA2026!
DEMO_CLINIC_NAME=Clinica Demo IA
DEMO_CLINIC_SLUG=clinica-demo-ia
