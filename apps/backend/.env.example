# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/meditrack

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-this-to-a-secure-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS + magic links)
FRONTEND_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@meditrack.app

# File Storage (S3 / R2)
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=meditrack-files
STORAGE_REGION=auto
