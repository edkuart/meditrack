# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/meditrack

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
FRONTEND_URL=http://localhost:3000
# Optional: comma-separated allowed web origins (production + previews)
FRONTEND_URLS=http://localhost:3000
# Optional: startup migration retry tuning for managed databases
DB_MIGRATION_ATTEMPTS=30
DB_MIGRATION_RETRY_DELAY_MS=5000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -base64 48
JWT_SECRET=change-me-in-production-must-be-at-least-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# https://resend.com → API Keys
# Leave blank during local development to log emails to the console instead
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=meditrack <noreply@yourdomain.com>

# ─── WhatsApp (Twilio) ────────────────────────────────────────────────────────
# https://console.twilio.com
# Leave blank during local development to log messages to the console instead
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio Sandbox: whatsapp:+14155238886  (prod: your registered number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Storage (AWS S3 or compatible, e.g. MinIO / Cloudflare R2) ───────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=meditrack-documents
# Optional: uncomment for S3-compatible services (MinIO, R2, etc.)
# AWS_S3_ENDPOINT=http://localhost:9000

# ─── Stripe Billing ────────────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
# Leave blank during local development to disable billing features
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Products → select your Pro plan → copy Price ID
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dashboard → Developers → Webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
